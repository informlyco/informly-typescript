{
  "name": "@informly/sdk",
  "version": "0.1.1",
  "description": "Official Informly API client for TypeScript/JavaScript",
  "author": "Informly",
  "license": "MIT",
  "keywords": [
    "informly",
    "api",
    "sdk",
    "rest",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/informlyco/informly-typescript"
  },
  "homepage": "https://www.informly.co",
  "type": "commonjs",
  "main": "./cjs/index.js",
  "module": "./esm/index.mjs",
  "types": "./cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./esm/index.d.mts",
        "default": "./esm/index.mjs"
      },
      "require": {
        "types": "./cjs/index.d.ts",
        "default": "./cjs/index.js"
      }
    }
  },
  "files": [
    "cjs",
    "esm"
  ],
  "browser": {
    "fs": false,
    "os": false,
    "path": false,
    "stream": false,
    "crypto": false
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
